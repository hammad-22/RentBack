# RentBack - Backend Environment Variables

# LLM Provider Configuration
# Options: "openai", "groq", "mistral", "ollama", "mock"
LLM_PROVIDER=mock

# OpenAI (if using OpenAI)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Groq (recommended - cheapest cloud option, $0.05/M tokens)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# Mistral (free tier available)
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL=mistral-small-latest

# Ollama (free, runs locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Data Source Configuration
# Options: "mock", "scrape", "api"
DATA_SOURCE=mock

# RentCast API (if using API-based data)
RENTCAST_API_KEY=your-rentcast-api-key-here

# Application Settings
DEFAULT_CITY=nyc
SEARCH_RADIUS_MILES=0.5
CORS_ORIGINS=http://localhost:3000
